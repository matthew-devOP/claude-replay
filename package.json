{
  "name": "claude-replay",
  "version": "0.6.0",
  "description": "Community tool to convert Claude Code session transcripts into self-contained, embeddable HTML replays",
  "type": "module",
  "bin": {
    "claude-replay": "bin/claude-replay.mjs"
  },
  "files": [
    "bin/",
    "src/",
    "template/"
  ],
  "scripts": {
    "build": "node scripts/build-template.mjs",
    "test": "node --test test/test-*.mjs",
    "test:e2e": "npx playwright test"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "node-pty": "^1.0.0",
    "ws": "^8.18.0",
    "@xterm/xterm": "^5.5.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "esbuild": "^0.25.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "claude",
    "claude-code",
    "replay",
    "transcript",
    "html"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/es617/claude-replay"
  },
  "license": "MIT"
}
